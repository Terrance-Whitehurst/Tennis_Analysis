# Data files (too large for git)
data/raw/
data/interim/
data/processed/
!data/**/.gitkeep

# Model checkpoints
models/*.pt

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/

# IDE
.vscode/
.idea/

# OS
.DS_Store

# Experiment outputs
experiments/
!experiments/.gitkeep

# TensorBoard logs
logs/
runs/

# pytest cache
.pytest_cache/

# Environment / secrets
.env
.env.*

# Jupyter checkpoints
.ipynb_checkpoints/

# Large model files (catch-all)
*.onnx
*.h5
*.pkl
*.pickle
*.joblib

